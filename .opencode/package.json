{
  "name": "@helldinhow/sdd-flow-opencode-plugin",
  "version": "0.6.0",
  "description": "OpenCode Spec-Driven Development workflow plugin and bootstrap kit",
  "homepage": "https://github.com/Heldinhow/sdd-flow#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Heldinhow/sdd-flow.git"
  },
  "bugs": {
    "url": "https://github.com/Heldinhow/sdd-flow/issues"
  },
  "keywords": [
    "opencode",
    "plugin",
    "sdd",
    "spec-driven-development",
    "planning"
  ],
  "type": "module",
  "exports": {
    ".": "./plugin/sdd.ts"
  },
  "files": [
    "plugin/**/*.ts",
    "src/**/*.ts",
    "skills/**/*.md",
    "scripts/**/*.js",
    "managed-assets/**/*"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "postinstall": "node scripts/install-skill.js",
    "prepublishOnly": "bunx tsc --noEmit && bun test tests/unit/packaging/"
  },
  "dependencies": {
    "@opencode-ai/plugin": "1.2.27",
    "@opencode-ai/sdk": "1.2.27",
    "zod": "4.1.8"
  },
  "devDependencies": {
    "@types/node": "22.13.9",
    "bun-types": "^1.3.11",
    "typescript": "5.8.2"
  }
}
